                  <td className="p-3 align-top border-l-2" style={{ borderColor: '#e2dec9' }}></td>
                  <td className="p-3 align-top border-l-2" style={{ borderColor: '#e2dec9' }}></td>
                  <td className="p-3 align-top border-l-2" style={{ borderColor: '#e2dec9' }}></td>
